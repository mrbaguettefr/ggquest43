    "version": "0.2.0",
    "configurations": [
        {
            "name": "Exploration (Chrome)",
            "request": "launch",
            "type": "chrome",
            "url": "http://localhost:8080?debugScene=Exploration",
            "webRoot": "${workspaceFolder}"
        },
        {
            "name": "Battle (Chrome)",
            "request": "launch",
            "type": "chrome",
            "url": "http://localhost:8080?debugScene=Battle",
            "webRoot": "${workspaceFolder}"
        },
        {
            "name": "Launch Integrated Browser",
            "request": "launch",
            "type": "editor-browser",
            "url": "http://localhost:8080?debugScene=Exploration",
            "webRoot": "${workspaceFolder}"
        }
    ]
}